# 抖音多用户视频监控脚本 —— 环境变量配置示例
# 部署时复制为 .env 并填写：cp env.example .env

# ------------------------------------------------------------------
# 通知渠道开关
# ------------------------------------------------------------------

# 启用哪些推送渠道，多个用英文逗号分隔，会同时推送到所有启用的渠道。
# 可选值：dingtalk / bark / wecom / serverchan / telegram
# 不填时默认只启用 dingtalk（兼容旧版本 .env）
# 示例：NOTIFY_CHANNELS=dingtalk,bark
NOTIFY_CHANNELS=dingtalk

# ------------------------------------------------------------------
# 钉钉自定义机器人配置（NOTIFY_CHANNELS 包含 dingtalk 时必填）
# ------------------------------------------------------------------

# 钉钉自定义机器人 Webhook 的 access_token
# 获取方式：钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
# Webhook 地址形如 https://oapi.dingtalk.com/robot/send?access_token=xxxxxx，
# 这里只需要填 access_token= 后面的那一串
DINGTALK_TOKEN=

# 钉钉自定义机器人的加签密钥，安全设置里选"加签"方式后会生成，
# 一定是以 SEC 开头，不要跟 access_token 搞混
DINGTALK_SECRET=

# 告警时需要 @ 的手机号，多个用英文逗号分隔，不需要就留空
# 示例：AT_MOBILES=13800000000,13900000000
AT_MOBILES=

# ------------------------------------------------------------------
# Bark 推送配置（NOTIFY_CHANNELS 包含 bark 时必填）
# 文档：https://bark.day.app/
# ------------------------------------------------------------------

# Bark 服务器地址，默认用官方服务器即可，自建服务器改成自己的地址
BARK_SERVER=https://api.day.app

# Bark App 里生成的设备 Key
BARK_DEVICE_KEY=

# ------------------------------------------------------------------
# 企业微信群机器人配置（NOTIFY_CHANNELS 包含 wecom 时必填）
# ------------------------------------------------------------------

# 企业微信群机器人 Webhook 里 key= 后面的那一串
WECOM_WEBHOOK_KEY=

# ------------------------------------------------------------------
# Server 酱配置（NOTIFY_CHANNELS 包含 serverchan 时必填）
# 文档：https://sct.ftqq.com/，可转发到微信
# ------------------------------------------------------------------

SERVERCHAN_SENDKEY=

# ------------------------------------------------------------------
# Telegram Bot 配置（NOTIFY_CHANNELS 包含 telegram 时必填）
# ------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ------------------------------------------------------------------
# 抓取接口配置
# ------------------------------------------------------------------

# 抓取抖音用户视频列表的接口地址（通常是你自己部署的
# Douyin_TikTok_Download_API 或类似服务）
# 默认值：http://localhost/api/douyin/web/fetch_user_post_videos
API_URL=http://localhost/api/douyin/web/fetch_user_post_videos

# 单次请求拉取的视频条数。如果监控的账号经常一次性发布很多条视频，
# 建议调大，否则超出这个数量的部分会被漏检（脚本检测到会打印警告提醒你）
# 默认值：10
FETCH_COUNT=10

# ------------------------------------------------------------------
# 过时 / Cookie 失效检测
# ------------------------------------------------------------------

# API 响应内容连续多久（单位：秒）不变，就提醒"疑似 Cookie 过期"
# 默认值：604800（7 天）
STALE_THRESHOLD=604800

# ------------------------------------------------------------------
# 轮询间隔
# ------------------------------------------------------------------

# 每轮检测之间的等待间隔（单位：秒），实际间隔为 [POLL_INTERVAL_MIN, POLL_INTERVAL_MAX] 之间的随机值
# 密集监控可设小（如 10），佛系监控可设大（如 300）
# 默认值：15~40
POLL_INTERVAL_MIN=15
POLL_INTERVAL_MAX=40

# ------------------------------------------------------------------
# 并发相关（一般不需要改动默认值）
# ------------------------------------------------------------------

# 并发检查账号数的安全上限。正常情况下真正控制请求节奏的是上面的轮询间隔，
# 这个值只是防止极端情况下（比如同时有多个账号的请求都卡在超时边缘）
# 同时挂起的请求数失控。
# 默认值：5
MAX_CONCURRENT_USERS=5

# ------------------------------------------------------------------
# 日志
# ------------------------------------------------------------------

# 终端 / journalctl 实时输出的详细程度，可选 DEBUG / INFO / WARNING / ERROR
# 只影响终端实时输出，不影响 log/info 和 log/debug 两个日志文件的内容
# 默认值：INFO
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Web 状态面板（可选）
# ------------------------------------------------------------------

# 是否随监控主循环一起启动一个只读的状态面板网页，默认关闭
# 面板本身不做鉴权，默认只监听本机回环地址，如需远程访问请自行加反向代理 + 鉴权
# 默认值：false
WEB_ENABLED=false

# 面板监听地址，默认只监听本机；如果要在局域网访问改成 0.0.0.0（注意安全风险）
WEB_HOST=127.0.0.1

# 面板监听端口
WEB_PORT=8787
