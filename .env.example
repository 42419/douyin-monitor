# 抖音多用户视频监控脚本 —— 环境变量配置示例
# 部署时复制为 .env 并填写：cp .env.example .env

# ------------------------------------------------------------------
# 钉钉自定义机器人配置（必填）
# ------------------------------------------------------------------

# 钉钉自定义机器人 Webhook 的 access_token
# 获取方式：钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
# Webhook 地址形如 https://oapi.dingtalk.com/robot/send?access_token=xxxxxx，
# 这里只需要填 access_token= 后面的那一串
DINGTALK_TOKEN=

# 钉钉自定义机器人的加签密钥，安全设置里选"加签"方式后会生成，
# 一定是以 SEC 开头，不要跟 access_token 搞混
DINGTALK_SECRET=

# 告警时需要 @ 的手机号，多个用英文逗号分隔，不需要就留空
# 示例：AT_MOBILES=13800000000,13900000000
AT_MOBILES=

# ------------------------------------------------------------------
# 抓取接口配置
# ------------------------------------------------------------------

# 抓取抖音用户视频列表的接口地址（通常是你自己部署的
# Douyin_TikTok_Download_API 或类似服务）
# 默认值：http://localhost/api/douyin/web/fetch_user_post_videos
API_URL=http://localhost/api/douyin/web/fetch_user_post_videos

# 单次请求拉取的视频条数。如果监控的账号经常一次性发布很多条视频，
# 建议调大，否则超出这个数量的部分会被漏检（脚本检测到会打印警告提醒你）
# 默认值：10
FETCH_COUNT=10

# ------------------------------------------------------------------
# 过时 / Cookie 失效检测
# ------------------------------------------------------------------

# API 响应内容连续多久（单位：秒）不变，就提醒"疑似 Cookie 过期"
# 默认值：604800（7 天）
STALE_THRESHOLD=604800

# ------------------------------------------------------------------
# 轮询间隔
# ------------------------------------------------------------------

# 每轮检测之间的等待间隔（单位：秒），实际间隔为 [POLL_INTERVAL_MIN, POLL_INTERVAL_MAX] 之间的随机值
# 密集监控可设小（如 10），佛系监控可设大（如 300）
# 默认值：15~40
POLL_INTERVAL_MIN=15
POLL_INTERVAL_MAX=40

# ------------------------------------------------------------------
# 并发相关（一般不需要改动默认值）
# ------------------------------------------------------------------

# 并发检查账号数的安全上限。正常情况下真正控制请求节奏的是上面的轮询间隔，
# 这个值只是防止极端情况下（比如同时有多个账号的请求都卡在超时边缘）
# 同时挂起的请求数失控。
# 默认值：5
MAX_CONCURRENT_USERS=5

# ------------------------------------------------------------------
# 日志
# ------------------------------------------------------------------

# 终端 / journalctl 实时输出的详细程度，可选 DEBUG / INFO / WARNING / ERROR
# 只影响终端实时输出，不影响 log/info 和 log/debug 两个日志文件的内容
# 默认值：INFO
LOG_LEVEL=INFO
