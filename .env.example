# 钉钉群机器人配置（必填）
# 在钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义机器人 中获取
# 安全设置请选择"加签"，下面两项分别对应 Webhook 中的 access_token 和加签密钥
DINGTALK_TOKEN=your_dingtalk_access_token
DINGTALK_SECRET=your_dingtalk_secret

# 抖音视频列表 API 地址（必填，按你实际部署的抓取服务地址填写）
API_URL=http://localhost/api/douyin/web/fetch_user_post_videos

# 可选：Cookie 过时检测阈值，单位秒，默认 7 天
STALE_THRESHOLD=604800

# 可选：单次请求拉取的视频条数，默认 10。
# 如果某个用户经常一次性发布很多视频（超过这个数），建议调大，
# 否则可能漏检（脚本会在日志里提示）。
FETCH_COUNT=10

# 可选：发生告警时需要 @ 的手机号，多个用逗号分隔
AT_MOBILES=

# 可选：终端（控制台输出）的日志级别，默认 INFO。
# 注意：这只影响"实时看屏幕/journalctl 输出"的详细程度，
# 两个日志文件（log/info/、log/debug/）始终各自完整记录，不受这个配置影响。
# 一般保持默认 INFO 即可；如果想让终端也实时刷出逐用户调试细节，改成 DEBUG。
LOG_LEVEL=INFO
